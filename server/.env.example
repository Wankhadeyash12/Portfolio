PORT=5000

# Public URL of this deployed app (used to build file/photo/resume URLs).
# Local dev:  http://localhost:5000
SERVER_URL=http://localhost:5000

# MongoDB connection string. Use MongoDB Atlas in production.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db-name>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://ywankhade014_db_user:zTYKraj1DrBvSxRi@myportfolio.3i6xmsm.mongodb.net/yash-portfolio?retryWrites=true&w=majority
MONGO_DB_NAME=yash-portfolio

# Long random string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# NEVER reuse the same secret across projects, and never commit the real value.
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS allow-list. This is needed for local development where the Vite dev
# server (5173) and the API (5000) run on different ports.
# Local dev:  http://localhost:5173
CLIENT_URL=http://localhost:5173

# Optional — only needed if you want the contact form to send you an email
# (it always saves messages to the database regardless).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Credentials used once, by `npm run setup:local`, to create your admin login.
# Change ADMIN_PASSWORD to something strong before running setup in production.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change_this_password
